# How Much AI — open-source self-hosted configuration
#
# Copy this file to .env.local for local use. Blank values are treated as unset.
# Never commit .env.local or replace these examples with real secrets.

# ── Access control ──────────────────────────────────────────────────────────────

# Optional for a local-only install; REQUIRED before exposing the app to a network.
# With no APP_PASSWORD, the dashboard and APIs are intentionally open.
APP_PASSWORD=

# Signs the password-session cookie. Defaults to APP_PASSWORD when blank.
# Set an independent random value so changing APP_PASSWORD does not invalidate sessions.
AUTH_SECRET=

# Trust forwarded client-IP headers only when a reverse proxy you control overwrites them.
# Leave disabled for direct hosting; client-supplied forwarding headers are otherwise spoofable.
TRUST_PROXY_IP_HEADERS=0

# Production-mode same-host convenience only. Set to 1 only when the browser operator and the
# Next.js server are on the same trusted machine and the server may read that machine's CLI logins.
# Leave disabled on every remote or multi-user server; use paste/private sign-in or pairing there.
ENABLE_LOCAL_CONNECT=0

# ── Vault encryption and local files ───────────────────────────────────────────

# Stable secret used to encrypt connected-account credentials. Strongly recommended for every
# networked deployment and REQUIRED before the first Redis-backed account is saved.
# Do not rotate or remove it until all existing vault data has been deliberately migrated.
VAULT_ENCRYPTION_SECRET=

# Optional local-file directory. Defaults to <repository>/.data.
# Keep this on a private, persistent volume and back up the whole directory together.
VAULT_DATA_DIR=

# ── Convex storage (optional) ──────────────────────────────────────────────────

# Configure both the deployment URL and access secret. A partial pair fails closed.
# `npx convex dev` normally writes NEXT_PUBLIC_CONVEX_URL to .env.local; the server accepts that
# generated URL when VAULT_ACCESS_SECRET is also set. CONVEX_URL is clearer for hosted servers.
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=

# Set the same value in the selected Convex deployment:
#   npx convex env set VAULT_ACCESS_SECRET
# Use `--prod` when targeting the default production deployment.
VAULT_ACCESS_SECRET=

# ── Redis/KV REST storage (optional) ───────────────────────────────────────────

# Configure one complete URL/token pair. These are REST credentials, not a redis:// connection.
# Convex takes precedence if a complete Convex configuration is present.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash aliases accepted by the app. Use these instead of KV_REST_API_* if your platform supplies
# the UPSTASH_REDIS_REST_* names automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Convex-backed notifications and device pairing (optional) ─────────────────

# Public origin of this app, without a trailing slash. Convex uses it to call /api/cron/check, and
# the pairing dialog uses it when it builds a command for another machine.
APP_URL=

# Shared secret between the Convex scheduler and this app. Set the same value in both places:
#   npx convex env set CRON_SECRET
CRON_SECRET=

# Telegram: create a bot, message it once, and configure its bot token and destination chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Generic destination. The app POSTs JSON containing source, text, and events.
WEBHOOK_URL=

# Browser Web Push. Generate a keypair with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=

# Contact URI for the VAPID key. Defaults to mailto:usage@localhost when blank.
VAPID_SUBJECT=
